{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE \"rm -rf|DROP TABLE|DELETE FROM\"; then echo \"⚠️ DESTRUCTIVE COMMAND BLOCKED. Use manual confirmation if required.\"; exit 1; fi"
          },
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q \"git push --force\"; then echo \"⚠️ FORCE PUSH BLOCKED. Use extreme caution.\"; exit 1; fi"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys, json; data=json.load(sys.stdin); path=data.get('tool_input', {}).get('file_path', ''); sys.exit(1) if any(s in path for s in ['.env', 'credentials']) else sys.exit(0)\" || (echo \"⚠️ BLOCKED: Attempting to write to sensitive file\" && exit 1)"
          },
          {
            "type": "command",
            "command": "python3 -c \"import sys, json; data=json.load(sys.stdin); path=data.get('tool_input', {}).get('file_path', ''); sys.exit(1) if 'db/schema.sql' in path else sys.exit(0)\" || (echo \"⚠️ BLOCKED: Editing base schema. Use migrations instead.\" && exit 1)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write:*.ts|Write:*.tsx|Edit:*.ts|Edit:*.tsx",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATHS\""
          }
        ]
      },
      {
        "matcher": "Write:*.md|Edit:*.md",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATHS\""
          }
        ]
      },
      {
        "matcher": "Write:app/api/*|Edit:app/api/*",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint -- --fix \"$CLAUDE_FILE_PATHS\""
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-rls-filter.sh \"$CLAUDE_FILE_PATHS\""
          }
        ]
      },
      {
        "matcher": "Write:tests/*|Write:*.test.ts",
        "hooks": [
          {
            "type": "command",
            "command": "npm test -- --run \"$CLAUDE_FILE_PATHS\""
          }
        ]
      },
      {
        "matcher": "Edit:lib/validators.ts",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"✅ Validator updated. Remember to update tests.\""
          }
        ]
      },
      {
        "matcher": "Write:db/migrations/*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-migration.sh \"$CLAUDE_FILE_PATHS\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_HOOK_INPUT\" | grep -iqE \"deploy|production\"; then .claude/hooks/pre-deploy-check.sh; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_HOOK_INPUT\" | grep -iq \"fail\"; then echo \"Tests Failed. Check output.\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cleanup-session.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/subagent-report.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/save-context.sh"
          }
        ]
      }
    ],
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/project-setup.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-end.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(npx *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(tree *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)",
      "Skill(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)"
    ]
  },
  "outputStyles": {
    "default": "production-ready",
    "available": [
      "production-ready",
      "quebec-french",
      "code-review"
    ]
  },
  "context": {
    "alwaysInclude": [
      "CLAUDE.md",
      "ENTRETIEN_PRESTIGE_FINAL_SPEC-1.md"
    ],
    "maxTokens": 50000
  }
}